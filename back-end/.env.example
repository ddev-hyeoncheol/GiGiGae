# GiGiGae Backend Environment Variables

# App
APP_NAME=GiGiGae API
DEBUG=true

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
# OLLAMA_MODEL=qwen3.5:4b
OLLAMA_TIMEOUT=120

# KIPRIS 상표권 API (비워두면 Mock 모드)
KIPRIS_API_KEY=

# NHN Cloud (비워두면 Mock 모드)
NHN_CLOUD_API_KEY=
NHN_CLOUD_API_URL=

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
