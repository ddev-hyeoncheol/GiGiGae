# GiGiGae Backend Environment Variables

# App
APP_NAME=GiGiGae API
DEBUG=true

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
# OLLAMA_MODEL=qwen3.5:4b
OLLAMA_TIMEOUT=120

# KIPRIS 상표권 API (비워두면 Mock 모드)
KIPRIS_API_KEY=

# NHN Cloud (비워두면 Mock 모드)
NHN_CLOUD_API_KEY=
NHN_CLOUD_API_URL=

# Database (Docker Compose에서 자동 주입, 로컬 개발 시 직접 설정)
# DATABASE_URL=postgresql+asyncpg://gigigae:gigigae@localhost:5432/gigigae

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
